# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/

# Virtual environments
venv/
.venv/
env/
.ENV/

# Runtime artifacts
transcripts.log
run.log
run_live.log
*.log
_work/
*.tmp

# Local scratch / debug scripts (underscore-prefixed one-offs)
_*.py
